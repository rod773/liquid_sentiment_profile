//═══════════════════════════════════════════════════════════════════════════════
// SHARED USER DEFINED TYPES
//═══════════════════════════════════════════════════════════════════════════════
type bar
    float o = open
    float h = high
    float l = low
    float c = close
    float v = volume
    int   i = bar_index

type pivotPoint
    int    x
    float  h
    float  h1
    float  l
    float  l1

type vector
    array<float> id

type holder
    array<vector> id

//═══════════════════════════════════════════════════════════════════════════════
// SHARED VARIABLES
//═══════════════════════════════════════════════════════════════════════════════
bar b = bar.new()
var pivotPoint pp = pivotPoint.new()
bull  = b.c > b.o
nzV   = nz(b.v)

//═══════════════════════════════════════════════════════════════════════════════
// SHARED FUNCTIONS
//═══════════════════════════════════════════════════════════════════════════════
f_drawLabelX(_x, _y, _text, _xloc, _yloc, _color, _style, _textcolor, _size, _textalign, _tooltip) =>
    var lb = label.new(_x, _y, _text, _xloc, _yloc, _color, _style, _textcolor, _size, _textalign, _tooltip)
    lb.set_xy(_x, _y)
    lb.set_text(_text)
    lb.set_tooltip(_tooltip)
    lb.set_textcolor(_textcolor)

f_log_regression(src, length) =>
    float sumX      = 0.0
    float sumY      = 0.0
    float sumXSqr   = 0.0
    float sumXY     = 0.0

    for i = 0 to length - 1
        val = math.log(src[i])
        per = i + 1.0
        sumX += per
        sumY += val
        sumXSqr += per * per
        sumXY += val * per

    slope = (length * sumXY - sumX * sumY) / (length * sumXSqr - sumX * sumX)
    intercept = (sumY - slope * sumX) / length

    [slope, intercept]

f_format_vol(float vol) =>
    string res = ""
    if vol >= 1000000
        res := str.tostring(vol / 1000000, "#.#") + "M"
    else if vol >= 1000
        res := str.tostring(vol / 1000, "#.#") + "k"
    else
        res := str.tostring(vol, "#")
    res

f_render_channel(length, channel_width, line_w, mid_disp, col_up, col_mid, col_low, fill_color, show_stats, show_vp, bin_count, max_w, vp_color, extend_ch, ext_bars, show_poc, poc_color) =>
    [slope, intercept] = f_log_regression(close, length)
    
    float reg_start = math.exp(intercept + slope * length)
    float reg_end   = math.exp(intercept)
    float deviation = ta.stdev(close, length)

    float upper_start = reg_start + deviation * channel_width
    float upper_end   = reg_end + deviation * channel_width
    float lower_start = reg_start - deviation * channel_width
    float lower_end   = reg_end - deviation * channel_width

    var line mid_line       = na
    var line upper_line     = na
    var line lower_line     = na
    var linefill fill       = na
    var label dir_label     = na
    var label stats_lbl     = na
    var line mid_ext        = na
    var line upper_ext      = na
    var line lower_ext      = na
    var polyline vp_poly    = na
    var line poc_line       = na

    if mid_disp
        if na(mid_line)
            mid_line := line.new(bar_index[length], reg_start, bar_index, reg_end, color=col_mid, style=line.style_dashed)
        else
            mid_line.set_xy1(bar_index[length], reg_start)
            mid_line.set_xy2(bar_index, reg_end)
    else
        line.delete(mid_line)

    if na(upper_line)
        upper_line := line.new(bar_index[length], upper_start, bar_index, upper_end, width=line_w, color=col_up)
    else
        upper_line.set_xy1(bar_index[length], upper_start)
        upper_line.set_xy2(bar_index, upper_end)
        upper_line.set_width(line_w)

    if na(lower_line)
        lower_line := line.new(bar_index[length], lower_start, bar_index, lower_end, width=line_w, color=col_low)
    else
        lower_line.set_xy1(bar_index[length], lower_start)
        lower_line.set_xy2(bar_index, lower_end)
        lower_line.set_width(line_w)

    if na(fill)
        fill := linefill.new(upper_line, lower_line, fill_color)
    else
        fill.set_color(fill_color)

    if extend_ch
        float reg_fwd   = math.exp(intercept - slope * ext_bars)
        float upper_fwd = reg_fwd + deviation * channel_width
        float lower_fwd = reg_fwd - deviation * channel_width
        
        if mid_disp
            if na(mid_ext)
                mid_ext := line.new(bar_index, reg_end, bar_index + ext_bars, reg_fwd, color=col_mid, style=line.style_dotted)
            else
                mid_ext.set_xy1(bar_index, reg_end)
                mid_ext.set_xy2(bar_index + ext_bars, reg_fwd)
        else
            line.delete(mid_ext)

        if na(upper_ext)
            upper_ext := line.new(bar_index, upper_end, bar_index + ext_bars, upper_fwd, color=col_up, style=line.style_dashed, width=line_w)
        else
            upper_ext.set_xy1(bar_index, upper_end)
            upper_ext.set_xy2(bar_index + ext_bars, upper_fwd)
            upper_ext.set_width(line_w)

        if na(lower_ext)
            lower_ext := line.new(bar_index, lower_end, bar_index + ext_bars, lower_fwd, color=col_low, style=line.style_dashed, width=line_w)
        else
            lower_ext.set_xy1(bar_index, lower_end)
            lower_ext.set_xy2(bar_index + ext_bars, lower_fwd)
            lower_ext.set_width(line_w)
    else
        line.delete(mid_ext)
        line.delete(upper_ext)
        line.delete(lower_ext)

    bool is_uptrend = reg_end > reg_start
    string arrow_text = is_uptrend ? "⇗" : "⇘"
    float label_y     = is_uptrend ? lower_start : upper_start
    string label_style = is_uptrend ? label.style_label_upper_right : label.style_label_lower_right
    string label_style1 = is_uptrend ? label.style_label_lower_right : label.style_label_upper_right
    color label_text_color = is_uptrend ? col_up : col_low

    if na(dir_label)
        dir_label := label.new(bar_index[length], label_y, text=arrow_text, style=label_style, color=color.new(color.black, 100), textcolor=label_text_color, size=size.large)
    else
        dir_label.set_xy(bar_index[length], label_y)
        dir_label.set_text(arrow_text)
        dir_label.set_style(label_style)
        dir_label.set_textcolor(label_text_color)
    
    float buy_vol = 0.0
    float sell_vol = 0.0
    float[] bin_vols = array.new_float(bin_count, 0.0)

    for i = 0 to length - 1
        if close[i] > open[i]
            buy_vol += volume[i]
        else if close[i] < open[i]
            sell_vol += volume[i]
        
        if show_vp
            float hist_reg_mid    = math.exp(intercept + slope * i)
            float hist_upper_line = hist_reg_mid + deviation * channel_width
            float hist_lower_line = hist_reg_mid - deviation * channel_width
            float hist_height     = hist_upper_line - hist_lower_line
            
            if close[i] >= hist_lower_line and close[i] <= hist_upper_line
                float bar_bin_step = hist_height / bin_count
                int bin_index = math.floor((close[i] - hist_lower_line) / bar_bin_step)
                bin_index := math.min(math.max(bin_index, 0), bin_count - 1)
                array.set(bin_vols, bin_index, array.get(bin_vols, bin_index) + volume[i])
            
    float total_vol = buy_vol + sell_vol
    float delta_pct = total_vol > 0 ? ((buy_vol - sell_vol) / total_vol) * 100 : 0.0
    
    string buy_str   = f_format_vol(buy_vol)
    string sell_str  = f_format_vol(sell_vol)
    string delta_str = (delta_pct >= 0 ? "+" : "") + str.tostring(delta_pct, "#.#") + "%"
    string stats_text = "Buy: " + buy_str + "\nSell: " + sell_str + "\nDelta: " + delta_str

    if show_stats and barstate.islast
        if na(stats_lbl)
            stats_lbl := label.new(bar_index[length], label_y, text=stats_text, style=label_style1, color=color.new(color.black, 100), textcolor=color.white, size=size.small)
        else
            stats_lbl.set_xy(bar_index[length], label_y)
            stats_lbl.set_text(stats_text)
    else
        label.delete(stats_lbl)

    if show_vp and barstate.islast
        float max_bin_vol = array.max(bin_vols)
        int poc_bin_idx = bin_vols.indexof(max_bin_vol) 
        
        chart.point[] vp_points = array.new<chart.point>()
        int start_index = bar_index[length]
        float total_start_height = upper_start - lower_start
        float start_bin_step = total_start_height / bin_count
        float channel_slope_per_bar = (reg_end - reg_start) / length

        if max_bin_vol > 0
            for idx = 0 to bin_count - 1
                float current_vol = array.get(bin_vols, idx)
                int calculated_width_bars = math.round((current_vol / max_bin_vol) * max_w)
                
                float price_bottom_start = lower_start + (idx * start_bin_step)
                float price_top_start    = price_bottom_start + start_bin_step

                float price_bottom_projected = price_bottom_start + (channel_slope_per_bar * calculated_width_bars)
                float price_top_projected    = price_top_start + (channel_slope_per_bar * calculated_width_bars)

                array.push(vp_points, chart.point.from_index(start_index, price_bottom_start))
                array.push(vp_points, chart.point.from_index(start_index + calculated_width_bars, price_bottom_projected))
                array.push(vp_points, chart.point.from_index(start_index + calculated_width_bars, price_top_projected))
                array.push(vp_points, chart.point.from_index(start_index, price_top_start))

            polyline.delete(vp_poly)
            vp_poly := polyline.new(vp_points, line_color=vp_color, fill_color=color.new(vp_color, 85), closed=false, line_width=1, force_overlay=true)
            
            if show_poc
                float poc_offset_from_bottom = (poc_bin_idx + 0.5) * start_bin_step
                float poc_start_y = lower_start + poc_offset_from_bottom
                float poc_end_y   = lower_end + poc_offset_from_bottom
                
                if na(poc_line)
                    poc_line := line.new(start_index, poc_start_y, bar_index, poc_end_y, color=poc_color, width=2, style=line.style_solid)
                else
                    line.set_xy1(poc_line, start_index, poc_start_y)
                    line.set_xy2(poc_line, bar_index, poc_end_y)
            else
                line.delete(poc_line)
    else
        polyline.delete(vp_poly)
        line.delete(poc_line)

    true

//═══════════════════════════════════════════════════════════════════════════════
// MANIPULATIONX — KILLZONES
//═══════════════════════════════════════════════════════════════════════════════
var inNy = false
bool nyKz = false
bool lonKz = false

if showKz
    nyKzSess = time(timeframe.period, nySess, sessTz)
    nyKz := not na(nyKzSess)
    nyStart = na(nyKzSess[1]) and not na(nyKzSess)
    if nyStart
        label.new(bar_index, high, ' NY Open ', color = nyColor, style = label.style_label_lower_left, textcolor = color.white, size = size.small)
    
    lonKzSess = time(timeframe.period, lonSess, sessTz)
    lonKz := not na(lonKzSess)
    
    inNy := not na(nyKzSess)
else
    inNy := false
    nyKz := false
    lonKz := false

//═══════════════════════════════════════════════════════════════════════════════
// MANIPULATIONX — SESSION BOXES
//═══════════════════════════════════════════════════════════════════════════════
bool showSessBoxes = timeframe.in_seconds() < 14400

sessLine = sessLineStyle == 'dashed' ? line.style_dashed : sessLineStyle == 'dotted' ? line.style_dotted : line.style_solid

inSession(sess) =>
    not na(time(timeframe.period, sess + ':1234567', sessTz))

entered(cond) =>
    cond and not cond[1]

exited(cond) =>
    not cond and cond[1]

asiaIn = inSession(asiaSess)
sydIn = inSession(sydSess)
londonIn = inSession(lonSess)
nySessIn = inSession(nySess)

var float asiaH = na
var float asiaL = na
var int asiaStart = na
var box asiaBox = na

var float sydH = na
var float sydL = na
var int sydStart = na
var box sydBox = na

var float lonH = na
var float lonL = na
var int lonStart = na
var box lonBox = na

var float nyH = na
var float nyL = na
var int nyStart = na
var box nyBox = na

var float asiaFinalHi = na
var float asiaFinalLo = na
var float sydFinalHi = na
var float sydFinalLo = na
var float lonFinalHi = na
var float lonFinalLo = na
var float nyFinalHi = na
var float nyFinalLo = na
var float lastFinHi = na
var float lastFinLo = na
var bool lastFinHiHit = false
var bool lastFinLoHit = false

if showSessions and showSessBoxes
    if entered(asiaIn)
        asiaH := high
        asiaL := low
        asiaStart := bar_index
        asiaBox := box.new(asiaStart, asiaH, bar_index, asiaL, xloc = xloc.bar_index, border_color = asiaColor, bgcolor = color.new(asiaColor, sessTransp))
        line.new(bar_index, close, bar_index, close, xloc = xloc.bar_index, extend = extend.none, color = asiaColor, width = 1, style = sessLine)
    if not na(asiaBox)
        if asiaIn
            asiaH := math.max(asiaH, high)
            asiaL := math.min(asiaL, low)
            box.set_top(asiaBox, asiaH)
            box.set_bottom(asiaBox, asiaL)
            box.set_right(asiaBox, bar_index)
        if exited(asiaIn)
            line.new(bar_index, close, bar_index, close, xloc = xloc.bar_index, extend = extend.none, color = asiaColor, width = 1, style = sessLine)
            label.new(int(math.round((asiaStart + bar_index) / 2)), (asiaH + asiaL) / 2, 'ASIA', style = label.style_label_center, color = color.new(color.white, 100), textcolor = asiaColor, size = size.large)
            asiaFinalHi := asiaH
            asiaFinalLo := asiaL
            lastFinHi := asiaH
            lastFinLo := asiaL
            lastFinHiHit := false
            lastFinLoHit := false
            asiaH := na
            asiaL := na
            asiaStart := na
            asiaBox := na

    if entered(sydIn)
        sydH := high
        sydL := low
        sydStart := bar_index
        sydBox := box.new(sydStart, sydH, bar_index, sydL, xloc = xloc.bar_index, border_color = sydColor, bgcolor = color.new(sydColor, sessTransp))
        line.new(bar_index, close, bar_index, close, xloc = xloc.bar_index, extend = extend.none, color = sydColor, width = 1, style = sessLine)
    if not na(sydBox)
        if sydIn
            sydH := math.max(sydH, high)
            sydL := math.min(sydL, low)
            box.set_top(sydBox, sydH)
            box.set_bottom(sydBox, sydL)
            box.set_right(sydBox, bar_index)
        if exited(sydIn)
            line.new(bar_index, close, bar_index, close, xloc = xloc.bar_index, extend = extend.none, color = sydColor, width = 1, style = sessLine)
            label.new(int(math.round((sydStart + bar_index) / 2)), (sydH + sydL) / 2, 'SYDNEY', style = label.style_label_center, color = color.new(color.white, 100), textcolor = sydColor, size = size.large)
            sydFinalHi := sydH
            sydFinalLo := sydL
            lastFinHi := sydH
            lastFinLo := sydL
            lastFinHiHit := false
            lastFinLoHit := false
            sydH := na
            sydL := na
            sydStart := na
            sydBox := na

    if entered(londonIn)
        lonH := high
        lonL := low
        lonStart := bar_index
        lonBox := box.new(lonStart, lonH, bar_index, lonL, xloc = xloc.bar_index, border_color = lonColor, bgcolor = color.new(lonColor, sessTransp))
        line.new(bar_index, close, bar_index, close, xloc = xloc.bar_index, extend = extend.none, color = lonColor, width = 1, style = sessLine)
    if not na(lonBox)
        if londonIn
            lonH := math.max(lonH, high)
            lonL := math.min(lonL, low)
            box.set_top(lonBox, lonH)
            box.set_bottom(lonBox, lonL)
            box.set_right(lonBox, bar_index)
        if exited(londonIn)
            line.new(bar_index, close, bar_index, close, xloc = xloc.bar_index, extend = extend.none, color = lonColor, width = 1, style = sessLine)
            label.new(int(math.round((lonStart + bar_index) / 2)), (lonH + lonL) / 2, 'LONDON', style = label.style_label_center, color = color.new(color.white, 100), textcolor = lonColor, size = size.large)
            lonFinalHi := lonH
            lonFinalLo := lonL
            lastFinHi := lonH
            lastFinLo := lonL
            lastFinHiHit := false
            lastFinLoHit := false
            lonH := na
            lonL := na
            lonStart := na
            lonBox := na

    if entered(nySessIn)
        nyH := high
        nyL := low
        nyStart := bar_index
        nyBox := box.new(nyStart, nyH, bar_index, nyL, xloc = xloc.bar_index, border_color = nyColor, bgcolor = color.new(nyColor, sessTransp))
        line.new(bar_index, close, bar_index, close, xloc = xloc.bar_index, extend = extend.none, color = nyColor, width = 1, style = sessLine)
    if not na(nyBox)
        if nySessIn
            nyH := math.max(nyH, high)
            nyL := math.min(nyL, low)
            box.set_top(nyBox, nyH)
            box.set_bottom(nyBox, nyL)
            box.set_right(nyBox, bar_index)
        if exited(nySessIn)
            line.new(bar_index, close, bar_index, close, xloc = xloc.bar_index, extend = extend.none, color = nyColor, width = 1, style = sessLine)
            label.new(int(math.round((nyStart + bar_index) / 2)), (nyH + nyL) / 2, 'NEW YORK', style = label.style_label_center, color = color.new(color.white, 100), textcolor = nyColor, size = size.large)
            nyFinalHi := nyH
            nyFinalLo := nyL
            lastFinHi := nyH
            lastFinLo := nyL
            lastFinHiHit := false
            lastFinLoHit := false
            nyH := na
            nyL := na
            nyStart := na
            nyBox := na

//═══════════════════════════════════════════════════════════════════════════════
// MANIPULATIONX — HTF FVG
//═══════════════════════════════════════════════════════════════════════════════
fvgDraw(tf, cBull, cBear, lbl) =>
    [h, l, h2, l2, t] = request.security(syminfo.tickerid, tf, [high, low, high[2], low[2], time])
    bullFvg = l > h2
    bearFvg = h < l2
    fresh = ta.change(t) != 0
    nyOk = not fvgNyOnly or inNy
    if nyOk and bullFvg[1] and fresh and math.abs(l[1] - h2[1]) >= fvgMinTicks * syminfo.mintick
        box.new(bar_index, l[1], bar_index + 40, h2[1], border_color = cBull, bgcolor = color.new(cBull, 80))
        label.new(bar_index, (l[1] + h2[1]) / 2, lbl, color = color.new(cBull, 50), style = label.style_label_center, textcolor = color.white, size = size.tiny)
    if nyOk and bearFvg[1] and fresh and math.abs(l2[1] - h[1]) >= fvgMinTicks * syminfo.mintick
        box.new(bar_index, l2[1], bar_index + 40, h[1], border_color = cBear, bgcolor = color.new(cBear, 80))
        label.new(bar_index, (l2[1] + h[1]) / 2, lbl, color = color.new(cBear, 50), style = label.style_label_center, textcolor = color.white, size = size.tiny)

if showFvg15
    fvgDraw('15', cFvgBull, cFvgBear, '15M')
if showFvg1h
    fvgDraw('60', cFvgBull, cFvgBear, '1H')
if showFvg4h
    fvgDraw('240', cFvgBull, cFvgBear, '4H')

//═══════════════════════════════════════════════════════════════════════════════
// MANIPULATIONX — IFVG (1m)
//═══════════════════════════════════════════════════════════════════════════════
var bIFVG = false
var sIFVG = false

if showIFVG
    [_, _, mOp, mCl, mHi1, mLo1] = request.security(syminfo.tickerid, '1', [high, low, open, close, high[1], low[1]])
    bIFVG := mCl < mOp and mCl < mLo1 and close > mHi1
    sIFVG := mCl > mOp and mCl > mHi1 and close < mLo1
    if bIFVG
        label.new(bar_index, low, ' IFVG', color = color.new(#00E676, 20), style = label.style_label_up, textcolor = color.white, size = size.tiny)
    if sIFVG
        label.new(bar_index, high, ' IFVG', color = color.new(#FF1744, 20), style = label.style_label_down, textcolor = color.white, size = size.tiny)
else
    bIFVG := false
    sIFVG := false

//═══════════════════════════════════════════════════════════════════════════════
// MANIPULATIONX — SMT DIVERGENCE
//═══════════════════════════════════════════════════════════════════════════════
var float pAudLo = na
var int pAudLoBar = na
var float pAudHi = na
var int pAudHiBar = na
var float pBoldLo = na
var int pBoldLoBar = na
var float pBoldHi = na
var int pBoldHiBar = na
var bSMT = false
var sSMT = false

audPl = ta.pivotlow(low, 2, 2)
audPh = ta.pivothigh(high, 2, 2)
boldPl = request.security(smtSymbol, timeframe.period, ta.pivotlow(low, 2, 2))
boldPh = request.security(smtSymbol, timeframe.period, ta.pivothigh(high, 2, 2))

if showSmt
    bSMT := false
    sSMT := false
    
    bLo = ta.valuewhen(not na(boldPl), boldPl, 0)
    bLoBar = ta.valuewhen(not na(boldPl), bar_index, 0)
    bHi = ta.valuewhen(not na(boldPh), boldPh, 0)
    bHiBar = ta.valuewhen(not na(boldPh), bar_index, 0)
    
    if not na(audPl)
        if not na(pAudLo) and not na(bLo) and audPl > pAudLo and bLo < pBoldLo
            bSMT := true
            line.new(pAudLoBar, pAudLo, bar_index, audPl, color = cSmtBull, width = 2)
            label.new(bar_index, low, ' SMT', color = cSmtBull, style = label.style_label_up, textcolor = color.white, size = size.small)
        pAudLo := audPl
        pAudLoBar := bar_index
        pBoldLo := bLo
        pBoldLoBar := bLoBar
    
    if not na(audPh)
        if not na(pAudHi) and not na(bHi) and audPh < pAudHi and bHi > pBoldHi
            sSMT := true
            line.new(pAudHiBar, pAudHi, bar_index, audPh, color = cSmtBear, width = 2)
            label.new(bar_index, high, ' SMT', color = cSmtBear, style = label.style_label_down, textcolor = color.white, size = size.small)
        pAudHi := audPh
        pAudHiBar := bar_index
        pBoldHi := bHi
        pBoldHiBar := bHiBar
else
    bSMT := false
    sSMT := false

//═══════════════════════════════════════════════════════════════════════════════
// MANIPULATIONX — LEVELS + LIQUIDITY SWEEPS
//═══════════════════════════════════════════════════════════════════════════════
swp = showSweep ? sweepTicks * syminfo.mintick : na
bool asiaHiSweep = false
bool asiaLoSweep = false
bool lonHiSweep = false
bool lonLoSweep = false
[dHi, dLo] = request.security(syminfo.tickerid, 'D', [high[1], low[1]])
var bool dHiHit = false
var bool dLoHit = false
var bool dNew = false
var line dHiLine = na
var line dLoLine = na
dNew := barstate.isfirst or timeframe.change('1D')
if dNew
    dHiHit := false
    dLoHit := false
    line.delete(dHiLine)
    line.delete(dLoLine)
    if showSweep and not na(dHi)
        dHiLine := line.new(bar_index[1], dHi, bar_index, dHi, color = color.new(#FFD600, 30), width = 1, extend = extend.right)
        dLoLine := line.new(bar_index[1], dLo, bar_index, dLo, color = color.new(#FFD600, 30), width = 1, extend = extend.right)

barHiSweep = false
barLoSweep = false
dHiSweep = showSweep and dNew and not dHiHit and high > dHi + swp and close < dHi
dLoSweep = showSweep and dNew and not dLoHit and low < dLo - swp and close > dLo
if dHiSweep
    barHiSweep := true
    dHiHit := true
if dLoSweep
    barLoSweep := true
    dLoHit := true

float sweepHiPrice = na
float sweepLoPrice = na

if showSweep
    if not lastFinHiHit and not na(lastFinHi) and high > lastFinHi + swp and close < lastFinHi
        lastFinHiHit := true
        sweepHiPrice := lastFinHi
    if not lastFinLoHit and not na(lastFinLo) and low < lastFinLo - swp and close > lastFinLo
        lastFinLoHit := true
        sweepLoPrice := lastFinLo

if not na(sweepHiPrice)
    label.new(bar_index, sweepHiPrice, ' SWEEP', color = color.new(#FF5252, 30), style = label.style_label_down, textcolor = color.white, size = size.tiny)
if not na(sweepLoPrice)
    label.new(bar_index, sweepLoPrice, ' SWEEP', color = color.new(#69F0AE, 30), style = label.style_label_up, textcolor = color.white, size = size.tiny)
asiaHiSweep := barHiSweep or not na(sweepHiPrice)
asiaLoSweep := barLoSweep or not na(sweepLoPrice)

//═══════════════════════════════════════════════════════════════════════════════
// MANIPULATIONX — DOL LEVELS
//═══════════════════════════════════════════════════════════════════════════════
dolPh = ta.pivothigh(high, 4, 4)
dolPl = ta.pivotlow(low, 4, 4)
if showDol and (not dolNyOnly or inNy)
    dolMin = dolMinTicks * syminfo.mintick
    var float lastDolHi = na
    var float lastDolLo = na
    var string dolLast = ''
    if not na(dolPh) and (dolLast == '' or dolLast == 'low') and (na(lastDolLo) or dolPh - lastDolLo >= dolMin)
        label.new(bar_index, high, 'DOL', color = cDol, style = label.style_label_down, textcolor = color.white, size = size.tiny)
        lastDolHi := dolPh
        dolLast := 'high'
        dolLast
    if not na(dolPl) and (dolLast == '' or dolLast == 'high') and (na(lastDolHi) or lastDolHi - dolPl >= dolMin)
        label.new(bar_index, low, 'DOL', color = cDol, style = label.style_label_up, textcolor = color.white, size = size.tiny)
        lastDolLo := dolPl
        dolLast := 'low'
        dolLast

//═══════════════════════════════════════════════════════════════════════════════
// MANIPULATIONX — CHECKLIST
//═══════════════════════════════════════════════════════════════════════════════
var label checklistLbl = na
if barstate.islast and na(checklistLbl)
    lbl = '1. NY session (15:00 Madrid)\n2. Mark out DOLs/FVGs\n3. Entry model (iFVG)\n4. SMT divergence (AUDUSD vs BOLD)'
    checklistLbl := label.new(bar_index, high, lbl, color = color.new(#1a1a2e, 30), style = label.style_label_lower_left, textcolor = color.white, size = size.normal)

//═══════════════════════════════════════════════════════════════════════════════
// MANIPULATIONX — ALERTS
//═══════════════════════════════════════════════════════════════════════════════
alertcondition(bSMT, 'Bullish SMT')
alertcondition(sSMT, 'Bearish SMT')
alertcondition(bIFVG, 'Bullish IFVG')
alertcondition(sIFVG, 'Bearish IFVG')
alertcondition(asiaHiSweep or lonHiSweep, 'Bearish Sweep')
alertcondition(asiaLoSweep or lonLoSweep, 'Bullish Sweep')

//═══════════════════════════════════════════════════════════════════════════════
// MACD FORECAST — METHODS
//═══════════════════════════════════════════════════════════════════════════════
n = bar_index

method populate(holder get_holder, idx, init_price)=>
    if get_holder.id.size() < idx+1
        get_holder.id.push(vector.new(array.new<float>(0)))

    get_holder.id.get(idx).id.unshift(close - init_price)
    
    if get_holder.id.get(idx).id.size() > maxMemory
        get_holder.id.get(idx).id.pop()

method forecast(holder get_holder, idx, init_price, upper_coords, mid_coords, lower_coords)=>
    max_horizon = get_holder.id.size()

    x = 0
    for i = idx-1 to math.min(idx+fcast, max_horizon-1) by 1
        get_vector = get_holder.id.get(i)
        
        upper = init_price + get_vector.id.percentile_linear_interpolation(upPer)
        mid   = init_price + get_vector.id.percentile_linear_interpolation(midPer)
        lower = init_price + get_vector.id.percentile_linear_interpolation(dnPer)

        upper_coords.push(chart.point.from_index(n+x, upper))
        mid_coords.push(chart.point.from_index(n+x, mid))
        lower_coords.unshift(chart.point.from_index(n+x, lower))
        x := x + 1

//═══════════════════════════════════════════════════════════════════════════════
// MACD FORECAST — CALCULATIONS
//═══════════════════════════════════════════════════════════════════════════════
var memory = map.new<int, holder>()
var up_idx = 0
var dn_idx = 0
var uptrend_init_price = close
var downtrend_init_price = close

[macd, signal, _] = ta.macd(close, fast, slow, sigLen)

if barstate.isfirst
    memory.put(1, holder.new(array.new<vector>(0)))
    memory.put(0, holder.new(array.new<vector>(0)))

trigger = switch trend
    'MACD' => ta.cross(macd, 0)
    => ta.cross(macd, signal)

uptrend = trend == 'MACD' ? macd > 0 : macd > signal
downtrend = trend == 'MACD' ? macd < 0 : macd < signal

uptrend_init_price := uptrend and not uptrend[1] ? close : uptrend_init_price
downtrend_init_price := downtrend and not downtrend[1] ? close : downtrend_init_price
init_value = uptrend ? uptrend_init_price : downtrend_init_price

if uptrend
    get_holder = memory.get(1)
    get_holder.populate(up_idx, uptrend_init_price)

if downtrend
    get_holder = memory.get(0)
    get_holder.populate(dn_idx, downtrend_init_price)

up_idx := not uptrend ? 0 : up_idx + 1
dn_idx := not downtrend ? 0 : dn_idx + 1

if trigger
    upper_coords = array.new<chart.point>(0)
    mid_coords = array.new<chart.point>(0)
    lower_coords = array.new<chart.point>(0)

    if uptrend
        get_holder = memory.get(1)
        get_holder.forecast(up_idx, uptrend_init_price, upper_coords, mid_coords, lower_coords)
    else
        get_holder = memory.get(0)
        get_holder.forecast(dn_idx, downtrend_init_price, upper_coords, mid_coords, lower_coords)
    
    polyline.delete(polyline.new(mid_coords, line_color = uptrend ? upLine : dnLine)[1])

    polyline.delete(polyline.new(array.concat(upper_coords, lower_coords)
      , line_color = na
      , fill_color = uptrend ? upArea : dnArea)
      [1])

//═══════════════════════════════════════════════════════════════════════════════
// MACD FORECAST — PLOTS
//═══════════════════════════════════════════════════════════════════════════════
init_plot = plot(init_value, "Reference Price", init_value != init_value[1] ? na : color.gray)
price_plot = plot(close, editable = false, display = display.none)

top_css = not signalArea ? na : uptrend ? signalBull : color.new(chart.bg_color, 100)
btm_css = not signalArea ? na : uptrend ? color.new(chart.bg_color, 100) : signalBear

fill(init_plot, price_plot,
  top_value = math.max(close, uptrend ? uptrend_init_price : downtrend_init_price),
  bottom_value = math.min(close, uptrend ? uptrend_init_price : downtrend_init_price),
  top_color = top_css,
  bottom_color = btm_css)

//═══════════════════════════════════════════════════════════════════════════════
// DUAL LOG REGRESSION CHANNEL — RENDER
//═══════════════════════════════════════════════════════════════════════════════
if macro_show_channel
    f_render_channel(macro_length, macro_width, macro_line_w, macro_mid_disp, macro_col_up, macro_col_mid, macro_col_low, macro_col_fill, macro_show_stats, macro_show_vp, macro_bins, macro_max_w, macro_vp_color, macro_extend, macro_ext_bars, macro_show_poc, macro_poc_color)
if short_show_channel
    f_render_channel(short_length, short_width, short_line_w, short_mid_disp, short_col_up, short_col_mid, short_col_low, short_col_fill, short_show_stats, short_show_vp, short_bins, short_max_w, short_vp_color, short_extend, short_ext_bars, short_show_poc, short_poc_color)

//═══════════════════════════════════════════════════════════════════════════════
// LIQUIDITY SENTIMENT PROFILE — CALCULATIONS
//═══════════════════════════════════════════════════════════════════════════════
rpVST = array.new_float(rpNR + 1, 0.)
rpVSB = array.new_float(rpNR + 1, 0.)
rpVSD = array.new_float(rpNR + 1, 0.)
var dRP = array.new_box()
var dPC = array.new_line()
var int   x2   = 0
var float pir  = na
var int   pp_x = na
var float pp_y = na

pp_h = ta.pivothigh(ppLen, ppLen)
pp_l = ta.pivotlow (ppLen, ppLen)
if not na(pp_h) and tfIN == 'Swing High'
    pp.h1 := pp.h
    pp.h  := pp_h
    pp_y  := pp_h
    pp_x  := b.i
if not na(pp_l) and tfIN == 'Swing Low'
    pp.l1 := pp.l
    pp.l  := pp_l
    pp_y  := pp_l
    pp_x  := b.i
if tfOT == 'D' and tfIN == 'Day' ? dayofweek != dayofweek[1] : bool(ta.change(time(tfOT)))
    x2 := b.i
rpLN = tfIN == 'Fixed Range' ? drpLN : barstate.islast ? tfIN == 'Swing High' or tfIN == 'Swing Low' ? last_bar_index - pp_x + ppLen : last_bar_index - x2 : 1
pHST = ta.highest(high, rpLN > 0 ? rpLN + 1 : 1)
pLST = ta.lowest (low , rpLN > 0 ? rpLN + 1 : 1)
pSTP = (pHST - pLST) / rpNR
if barstate.islast and bool(nzV) and timeframe.period != tfOT and rpLN > 1 and pSTP > 0
    if dRP.size() > 0
        for i = 0 to dRP.size() - 1 by 1
            box.delete(dRP.shift())
    if dPC.size() > 0
        for i = 0 to dPC.size() - 1 by 1
            line.delete(dPC.shift())
    for bI = rpLN to 0 by 1
        lpCnt = 0
        for pLL = pLST to pHST by pSTP
            if (b[bI]).h >= pLL and (b[bI]).l < pLL + pSTP
                rpVST.set(lpCnt, rpVST.get(lpCnt) + nzV[bI] * (((b[bI]).h - (b[bI]).l) == 0 ? 1 : pSTP / ((b[bI]).h - (b[bI]).l)) )
                
                if bull[bI]
                    rpVSB.set(lpCnt, rpVSB.get(lpCnt) + nzV[bI] * (((b[bI]).h - (b[bI]).l) == 0 ? 1 : pSTP / ((b[bI]).h - (b[bI]).l)) )
            lpCnt := lpCnt + 1
        if rpPC
            if bI == rpLN 
                pir := pLST + (rpVST.indexof(rpVST.max()) + .50) * pSTP
            else
                dPC.push(line.new((b[bI]).i - 1, pir, (b[bI]).i, pLST + (rpVST.indexof(rpVST.max()) + .50) * pSTP, color = rpPCC, width = rpPCW))
                pir := pLST + (rpVST.indexof(rpVST.max()) + .50) * pSTP
    for lpCnt = 0 to rpNR - 1 by 1
        bbp  = 2 * rpVSB.get(lpCnt) - rpVST.get(lpCnt)
        rpVSD.set(lpCnt, rpVSD.get(lpCnt) + bbp * (bbp > 0 ? 1 : -1) )
    if rpBG
        dRP.push(box.new(b.i - rpLN, pLST, b.i, pHST, rpBGC, bgcolor = rpBGC ))
    if rpPL
        f_drawLabelX(b.i + drpHO + rpLN * rpW, pHST, str.tostring(pHST, format.mintick), xloc.bar_index, yloc.price, color(na), label.style_label_down, rpPLC, rpS, text.align_left, 'Profile High - ' + str.tostring(pHST, format.mintick) + '\n %' + str.tostring((pHST - pLST) / pLST * 100, '#.##') + ' higher than the Profile Low\n\nNumber of bars : ' + str.tostring(rpLN))
        f_drawLabelX(b.i + drpHO + rpLN * rpW, pLST, str.tostring(pLST, format.mintick), xloc.bar_index, yloc.price, color(na), label.style_label_up  , rpPLC, rpS, text.align_left, 'Profile Low - '  + str.tostring(pLST, format.mintick) + '\n %' + str.tostring((pHST - pLST) / pHST * 100, '#.##') + ' lower than the Profile High\n\nNumber of bars : ' + str.tostring(rpLN))
        if tfIN == 'Swing High'
            swH = pp.h > pp.h1 ? "HH" : pp.h < pp.h1 ? "LH" : na
            f_drawLabelX((b[rpLN]).i, pp.h, swH, xloc.bar_index, yloc.price, color(na), label.style_label_down, rpPLC, rpS, text.align_center, 'Swing High : ' + str.tostring(pp.h, format.mintick))
        
        if tfIN == 'Swing Low'
            swL = pp.l < pp.l1 ? "LL" : pp.l > pp.l1 ? "HL" : na
            f_drawLabelX((b[rpLN]).i, pp.l ,swL, xloc.bar_index, yloc.price, color(na), label.style_label_up  , rpPLC, rpS, text.align_center, 'Swing Low : '  + str.tostring(pp.l, format.mintick))
    for lpCnt = 0 to rpNR - 1 by 1
        if vpSH
            sBI = b.i - int(rpVST.get(lpCnt) / rpVST.max() * rpLN * rpW) + rpLN * rpW + drpHO
            eBI = b.i + drpHO + rpLN * rpW
            llC = rpVST.get(lpCnt) / rpVST.max() > vpHVT ? color.from_gradient(rpVST.get(lpCnt) / rpVST.max(), vpHVT, 1, vpAVC, vpHVC) : color.from_gradient(rpVST.get(lpCnt) / rpVST.max(), 0, vpLVT, vpLVC, vpAVC)
            dRP.push(box.new(sBI, pLST + (lpCnt + 0.1) * pSTP, eBI, pLST + (lpCnt + 0.9) * pSTP, color(na), bgcolor = llC ))
        if spSH
            bbp = 2 * rpVSB.get(lpCnt) - rpVST.get(lpCnt)
            sBI = b.i + int( rpVSD.get(lpCnt) / rpVSD.max() * rpLN * rpW / 2) + rpLN * rpW + drpHO
            eBI = b.i + drpHO + rpLN * rpW
            dRP.push(box.new(sBI, pLST + (lpCnt + 0.1) * pSTP, eBI, pLST + (lpCnt + 0.9) * pSTP, bbp > 0 ? spBLC : spBRC, bgcolor = bbp > 0 ? spBLC : spBRC ))
        if sdSH and rpVST.get(lpCnt) / rpVST.max() < sdTH
            dRP.push(box.new(b.i - rpLN, pLST + (lpCnt + 0.) * pSTP, b.i, pLST + (lpCnt + 1.) * pSTP, color(na), bgcolor = pLST + (lpCnt + .5) * pSTP > pLST + (rpVST.indexof(rpVST.max()) + .5) * pSTP ? sdCR : sdCS))