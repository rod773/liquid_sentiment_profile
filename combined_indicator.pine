//@version=6
indicator('ManipulationX + Liquidity Sentiment + Dual LogReg', 'MX+LSP+DLR', true, max_bars_back = 5000, max_boxes_count = 500, max_lines_count = 500, max_labels_count = 500)

//═══════════════════════════════════════════════════════════════════════════════
// MANIPULATIONX SETTINGS
//═══════════════════════════════════════════════════════════════════════════════
mxGR  = 'ManipulationX'
showFvg15 = input.bool(true, 'Show 15m FVG', group = mxGR)
showFvg1h = input.bool(true, 'Show 1h FVG', group = mxGR)
showFvg4h = input.bool(false, 'Show 4h FVG', group = mxGR)
fvgMinTicks = input.int(8, 'Min FVG Gap (ticks)', minval = 1, maxval = 50, group = mxGR)
fvgNyOnly = input.bool(true, 'FVG only during NY session', group = mxGR)
showIFVG = input.bool(true, 'Show iFVGs', group = mxGR)
showSmt = input.bool(true, 'Show SMT Divergence', group = mxGR)
smtSymbol = input.symbol('BOLDUSD', 'BOLD Symbol', group = mxGR)
showSweep = input.bool(true, 'Show Liquidity Sweeps', group = mxGR)
sweepTicks = input.int(2, 'Sweep Threshold (ticks)', minval = 1, maxval = 20, group = mxGR)
showDol = input.bool(true, 'Show DOL Levels', group = mxGR)
dolMinTicks = input.int(16, 'Min DOL Swing (ticks)', minval = 4, maxval = 200, group = mxGR)
dolNyOnly = input.bool(true, 'DOL only during NY session', group = mxGR)
showKz = input.bool(true, 'Use Killzones', group = mxGR)
showSessions = input.bool(true, 'Show Session Boxes', group = mxGR)
asiaSess = input.session('0100-0900', 'Asia session', group = mxGR)
asiaColor = input.color(color.yellow, 'Asia color', group = mxGR)
sydSess = input.session('2300-0700', 'Sydney session', group = mxGR)
sydColor = input.color(color.rgb(255, 69, 0), 'Sydney color', group = mxGR)
lonSess = input.session('0900-1700', 'London session', group = mxGR)
lonColor = input.color(color.blue, 'London color', group = mxGR)
nySess = input.session('1500-2200', 'New York session', group = mxGR)
nyColor = input.color(color.purple, 'New York color', group = mxGR)
sessTransp = input.int(85, 'Session box transparency', group = mxGR)
sessLineStyle = input.string('solid', 'Session line style', options = ['solid', 'dashed', 'dotted'], group = mxGR)
sessTz = input.string('Europe/Madrid', 'Session timezone', options = ['America/New_York', 'Europe/London', 'Europe/Madrid', 'Asia/Tokyo'], group = mxGR)
cFvgBull = input.color(color.new(#00ff88, 50), 'Bullish FVG', group = mxGR)
cFvgBear = input.color(color.new(#ff4444, 50), 'Bearish FVG', group = mxGR)
